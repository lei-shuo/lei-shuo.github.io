    "script": "<script>document.addEventListener('DOMContentLoaded',function(){var s=document.createElement('style');s.innerHTML='@keyframes f{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}body{background:linear-gradient(-45deg,#ee7752,#e73c7e,#23a6d5,#23d5ab)!important;background-size:400% 400%!important;animation:f 15s ease infinite!important;background-attachment:fixed!important}.markdown-body,.side,.FileList{background:rgba(255,255,255,0.7)!important;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-radius:12px;border:1px solid rgba(255,255,255,0.3)}.Header,.footer{background:transparent!important}.toc{position:fixed;left:20px;top:80px;width:200px;max-height:70vh;overflow-y:auto;background:rgba(255,255,255,0.6);backdrop-filter:blur(5px);padding:15px;border-radius:10px;box-shadow:0 4px 15px rgba(0,0,0,0.1);z-index:999}.toc a{display:block;color:#555;text-decoration:none;font-size:13px;margin-bottom:6px;padding:5px;border-radius:4px;transition:0.2s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.toc a:hover{background:rgba(255,255,255,0.9);color:#e73c7e;transform:translateX(5px)}@media(max-width:900px){.toc{display:none}}';document.head.appendChild(s);fetch('/blogBase.json').then(r=>r.json()).then(d=>{var n=document.createElement('div');n.className='toc';var t=document.createElement('div');t.innerText='📌 导航';t.style.fontWeight='bold';t.style.marginBottom='10px';n.appendChild(t);Object.values(d).sort((a,b)=>b.id-a.id).forEach(p=>{var l=document.createElement('a');l.href=p.postUrl;l.innerText=p.postTitle;l.title=p.postTitle;n.appendChild(l)});document.body.appendChild(n)}).catch(e=>console.log(e));});</script>"
