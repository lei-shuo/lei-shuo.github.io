    "script": "<script src='https://cdn.jsdelivr.net/npm/view-image.js@2.0.0/view-image.min.js'></script><script src='//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js'></script><script>document.addEventListener('DOMContentLoaded',function(){var style=document.createElement('style');style.innerHTML='/* 1. 背景修复：固定全屏流光 */ body{margin:0;padding:0;min-height:100vh;background-attachment:fixed;} body::before{content:\"\";position:fixed;top:0;left:0;width:100%;height:100%;z-index:-2;background:linear-gradient(125deg,#a18cd1 0%,#fbc2eb 100%);background-size:400% 400%;animation:grad 15s ease infinite;} @keyframes grad{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}} /* 2. 侧边栏：左侧固定 */ #side-panel{position:fixed;top:20px;left:20px;bottom:20px;width:250px;background:rgba(255,255,255,0.95);border-radius:12px;z-index:999;box-shadow:0 8px 30px rgba(0,0,0,0.1);display:flex;flex-direction:column;padding:15px;border:1px solid #fff;transition:transform 0.3s;} /* 3. 内容区域：智能右移 */ @media(min-width:1100px){ body{padding-left:290px!important;} .markdown-body, .FileList{width:auto!important;margin:20px auto!important;max-width:1000px!important;background:rgba(255,255,255,0.95)!important;border-radius:12px;padding:35px!important;box-shadow:0 5px 15px rgba(0,0,0,0.05);} .Header, .footer{background:transparent!important;} } /* 4. 手机端适配 */ @media(max-width:1099px){ #side-panel{transform:translateX(-120%);left:10px;top:10px;bottom:10px;} #side-panel.open{transform:translateX(0);} #mobile-menu{display:flex!important;} .markdown-body, .FileList{margin:10px!important;padding:15px!important;background:rgba(255,255,255,0.95)!important;border-radius:10px;} } /* 组件样式 */ #mobile-menu{display:none;position:fixed;left:20px;bottom:30px;width:50px;height:50px;background:#a18cd1;color:white;border-radius:50%;align-items:center;justify-content:center;font-size:24px;box-shadow:0 5px 15px rgba(161,140,209,0.5);z-index:10000;cursor:pointer;} #search-bar{width:100%;padding:10px;border:2px solid #f0f0f0;border-radius:8px;margin-bottom:15px;outline:none;background:#f9f9f9;} #search-bar:focus{border-color:#a18cd1;background:white;} .nav-cat{font-weight:bold;color:#555;margin:15px 0 5px;font-size:14px;border-bottom:2px solid #fbc2eb;padding-bottom:2px;} .nav-link{display:block;padding:8px;color:#666;text-decoration:none;font-size:14px;border-radius:6px;transition:0.2s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;} .nav-link:hover{background:linear-gradient(90deg,#a18cd1,#fbc2eb);color:white;}';document.head.appendChild(style);var nav=document.createElement('div');nav.id='side-panel';nav.innerHTML='<div style=\"text-align:center;margin-top:20px;color:#666\">🔄 目录加载中...</div>';document.body.appendChild(nav);var btn=document.createElement('div');btn.id='mobile-menu';btn.innerHTML='☰';btn.onclick=function(){nav.classList.toggle('open')};document.body.appendChild(btn);window.ViewImage && ViewImage.init('.markdown-body img');/* 智能路径获取 */ var basePath = window.location.origin + '/blogBase.json?t=' + Date.now(); fetch(basePath).then(res=>{ if(res.status===404){nav.innerHTML='<div style=\"color:red;padding:10px\">⚠️ 404错误<br>正在等待数据文件生成...<br>请稍后刷新页面</div>';return null;} return res.json(); }).then(data=>{ if(!data)return; nav.innerHTML=''; var inp=document.createElement('input');inp.id='search-bar';inp.placeholder='🔍 搜索文章...';inp.oninput=function(e){var v=e.target.value.toLowerCase();nav.querySelectorAll('.nav-link').forEach(l=>{l.style.display=l.innerText.toLowerCase().includes(v)?'block':'none'})};nav.appendChild(inp);var title=document.createElement('h3');title.innerText='LeiShuo';title.style.margin='0 0 15px 0';title.style.color='#444';nav.appendChild(title);var map={};Object.values(data).forEach(p=>{var l=p.labels[0]||'未分类';if(!map[l])map[l]=[];map[l].push(p)});Object.keys(map).sort().forEach(k=>{var c=document.createElement('div');c.className='nav-cat';c.innerText=k;nav.appendChild(c);map[k].forEach(p=>{var a=document.createElement('a');a.className='nav-link';a.href=p.postUrl;a.innerText=p.postTitle;nav.appendChild(a)})})}).catch(e=>{console.error(e);});});</script>"
}
