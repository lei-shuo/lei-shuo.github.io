    "iconList": {},
    "exlink": {},
    "commentLabelColor": "#006b75",
    "yearColorList": ["#bc4c00", "#0969da", "#1f883d", "#A333D0"],
    "i18n": "CN",
    "themeMode": "manual",
    "dayTheme": "light",
    "nightTheme": "dark",
    "urlMode": "pinyin",
    "style": "",
    "script": "<script src='https://cdn.jsdelivr.net/npm/view-image.js@2.0.0/view-image.min.js'></script><script src='//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js'></script><script>document.addEventListener('DOMContentLoaded',function(){var style=document.createElement('style');style.innerHTML='/* 1. 全局背景流光 */ body{margin:0;padding:0;min-height:100vh;background:linear-gradient(300deg,#ff9a9e,#fad0c4,#fad0c4,#a18cd1,#fbc2eb);background-size:400% 400%;animation:bgAnim 15s ease infinite;background-attachment:fixed;} @keyframes bgAnim{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}} /* 2. 侧边栏基础样式 */ #side-menu{position:fixed;top:0;left:0;width:260px;height:100%;background:rgba(255,255,255,0.95);z-index:99999;overflow-y:auto;padding:20px;box-shadow:2px 0 10px rgba(0,0,0,0.1);display:flex;flex-direction:column;border-right:1px solid #eee;transition:transform 0.3s ease;} /* 3. 电脑端布局 (关键修改) */ @media (min-width: 1000px) { body { padding-left: 270px !important; } /* 让body整体右移 */ .markdown-body, .FileList { width: auto !important; max-width: 1000px !important; background: rgba(255,255,255,0.9) !important; padding: 30px !important; border-radius: 10px; margin: 20px auto !important; } .Header, .footer { background: transparent !important; } } /* 4. 手机端布局 */ @media (max-width: 999px) { #side-menu { transform: translateX(-100%); } #side-menu.active { transform: translateX(0); } #mobile-btn { display: flex !important; } .markdown-body, .FileList { background: rgba(255,255,255,0.9) !important; margin: 10px !important; padding: 15px !important; border-radius: 10px; } } /* 5. 元素样式 */ #mobile-btn { display: none; position: fixed; left: 20px; bottom: 20px; width: 50px; height: 50px; background: #ff9a9e; color: white; border-radius: 50%; justify-content: center; align-items: center; font-size: 24px; box-shadow: 0 4px 10px rgba(0,0,0,0.2); z-index: 100000; cursor: pointer; } #search-inp { width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px; margin-bottom: 15px; background: #f9f9f9; color: #333; outline: none; } #search-inp:focus { border-color: #ff9a9e; background: white; } .menu-group { font-weight: bold; margin: 15px 0 5px; color: #333; border-bottom: 2px solid #fad0c4; padding-bottom: 5px; font-size: 15px; } .menu-link { display: block; padding: 8px; text-decoration: none; color: #555; font-size: 14px; border-radius: 5px; margin-bottom: 2px; } .menu-link:hover { background: linear-gradient(90deg,#ff9a9e,#fad0c4); color: white; } #loading-text { color: #666; text-align: center; margin-top: 20px; }';document.head.appendChild(style);/* 创建侧边栏 */ var nav=document.createElement('div');nav.id='side-menu';nav.innerHTML='<div id=\"loading-text\">⏳ 正在加载目录...</div>';document.body.appendChild(nav);/* 创建手机按钮 */ var btn=document.createElement('div');btn.id='mobile-btn';btn.innerHTML='☰';btn.onclick=function(){nav.classList.toggle('active')};document.body.appendChild(btn);/* 插件初始化 */ window.ViewImage && ViewImage.init('.markdown-body img');/* 获取数据 */ fetch('/blogBase.json').then(r=>r.json()).then(d=>{/* 清空Loading */ nav.innerHTML='';/* 搜索框 */ var inp=document.createElement('input');inp.id='search-inp';inp.placeholder='🔍 搜索文章...';inp.oninput=function(e){var v=e.target.value.toLowerCase();nav.querySelectorAll('.menu-link').forEach(l=>{l.style.display=l.innerText.toLowerCase().includes(v)?'block':'none'})};nav.appendChild(inp);/* 博客标题 */ var h=document.createElement('h3');h.innerText='📚 导航';h.style.color='#333';h.style.marginTop='0';nav.appendChild(h);/* 处理数据 */ var map={};Object.values(d).forEach(p=>{var l=p.labels[0]||'未分类';if(!map[l])map[l]=[];map[l].push(p)});Object.keys(map).sort().forEach(k=>{var g=document.createElement('div');g.className='menu-group';g.innerText=k;nav.appendChild(g);map[k].forEach(p=>{var a=document.createElement('a');a.className='menu-link';a.href=p.postUrl;a.innerText=p.postTitle;nav.appendChild(a)})});}).catch(e=>{console.error(e);nav.innerHTML='<div style=\"color:red\">❌ 目录加载失败</div>'});});</script>"
}
