{
    "title": "Lei Shuo's Blog",
    "subTitle": "Welcome to my personal blog",
    "avatarUrl": "https://github.githubassets.com/favicons/favicon.svg",
    "GMEEK_VERSION": "last",
    "displayTitle": "LeiShuo",
    "homeUrl": "https://lei-shuo.github.io",
    "faviconUrl": "https://github.githubassets.com/favicons/favicon.svg",
    "email": "meekdai@163.com",
    "startSite": "01/25/2026",
    "filingNum": "",
    "onePageListNum": 20,
    "singlePage": [],
    "iconList": {},
    "exlink": {},
    "commentLabelColor": "#006b75",
    "yearColorList": ["#bc4c00", "#0969da", "#1f883d", "#A333D0"],
    "i18n": "CN",
    "themeMode": "manual",
    "dayTheme": "light",
    "nightTheme": "dark",
    "urlMode": "pinyin",
    "style": "",
    "script": "<script src='https://cdn.jsdelivr.net/npm/view-image.js@2.0.0/view-image.min.js'></script><script src='//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js'></script><script>document.addEventListener('DOMContentLoaded',function(){var style=document.createElement('style');style.innerHTML='/* 1. 极光流体背景 (修复位置不对问题) */ body{margin:0;padding:0;min-height:100vh;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);background-attachment:fixed;} /* 动态光斑层 */ body::before {content:\"\"; position:fixed; top:0; left:0; width:100%; height:100%; background:linear-gradient(45deg, rgba(255,0,150,0.2), rgba(0,204,255,0.2)); z-index:-1; animation: aurora 10s ease infinite; background-size: 200% 200%;} @keyframes aurora {0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%}} /* 2. 侧边栏 (玻璃拟态) */ #side-menu{position:fixed;top:20px;left:20px;bottom:20px;width:260px;background:rgba(255,255,255,0.92);backdrop-filter:blur(12px);border-radius:15px;z-index:999;box-shadow:0 8px 32px rgba(0,0,0,0.1);padding:20px;display:flex;flex-direction:column;border:1px solid rgba(255,255,255,0.6);transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);} /* 3. 电脑端布局优化 (不再挤压body) */ @media (min-width: 1200px) { .markdown-body, .FileList { margin-left: 310px !important; width: calc(100% - 350px) !important; max-width: 1000px !important; background: rgba(255,255,255,0.95) !important; padding: 40px !important; border-radius: 15px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); border: 1px solid rgba(255,255,255,0.5); } .Header, .footer { margin-left: 310px !important; width: auto !important; background: transparent !important; } } /* 4. 手机端布局 */ @media (max-width: 1199px) { #side-menu { transform: translateX(-120%); left: 10px; top: 10px; bottom: 10px; } #side-menu.active { transform: translateX(0); } .markdown-body, .FileList { margin: 15px !important; background: rgba(255,255,255,0.95) !important; border-radius: 12px; padding: 20px !important; } #mobile-btn { display: flex !important; } } /* 元素样式 */ #mobile-btn { display: none; position: fixed; left: 20px; bottom: 30px; width: 50px; height: 50px; background: #667eea; color: white; border-radius: 50%; justify-content: center; align-items: center; font-size: 24px; box-shadow: 0 5px 15px rgba(102,126,234,0.4); z-index: 10000; cursor: pointer; transition: 0.2s; } #mobile-btn:active { transform: scale(0.9); } #search-inp { width: 100%; padding: 12px; border: 2px solid #eef1f5; border-radius: 10px; margin-bottom: 20px; background: #f8f9fa; outline: none; transition: 0.3s; } #search-inp:focus { border-color: #667eea; background: white; box-shadow: 0 0 0 3px rgba(102,126,234,0.1); } .menu-cat { font-weight: 700; color: #4a5568; margin: 15px 0 8px; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; } .menu-link { display: block; padding: 10px; color: #4a5568; text-decoration: none; font-size: 14px; border-radius: 8px; margin-bottom: 4px; transition: 0.2s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; } .menu-link:hover { background: #eef1f5; color: #667eea; transform: translateX(4px); } #err-msg { color: #e53e3e; font-size: 12px; margin-top: 10px; word-break: break-all; }';document.head.appendChild(style);var nav=document.createElement('div');nav.id='side-menu';nav.innerHTML='<div style=\"text-align:center;color:#666;margin-top:20px\">🚀 读取数据中...</div>';document.body.appendChild(nav);var btn=document.createElement('div');btn.id='mobile-btn';btn.innerHTML='☰';btn.onclick=function(){nav.classList.toggle('active')};document.body.appendChild(btn);window.ViewImage && ViewImage.init('.markdown-body img');/* 核心修复：使用绝对路径 + 时间戳防缓存 */ const jsonUrl = 'https://lei-shuo.github.io/blogBase.json?t=' + new Date().getTime(); fetch(jsonUrl).then(r=>{ if(!r.ok){throw new Error('HTTP状态: ' + r.status)} return r.json() }).then(d=>{nav.innerHTML='';var inp=document.createElement('input');inp.id='search-inp';inp.placeholder='🔍 搜索文章...';inp.oninput=function(e){var v=e.target.value.toLowerCase();nav.querySelectorAll('.menu-link').forEach(l=>{l.style.display=l.innerText.toLowerCase().includes(v)?'block':'none'})};nav.appendChild(inp);var h=document.createElement('h3');h.innerText='LeiShuo Blog';h.style.margin='0 0 20px 0';h.style.color='#2d3748';nav.appendChild(h);var map={};Object.values(d).forEach(p=>{var l=p.labels[0]||'其他';if(!map[l])map[l]=[];map[l].push(p)});Object.keys(map).sort().forEach(k=>{var c=document.createElement('div');c.className='menu-cat';c.innerText=k;nav.appendChild(c);map[k].forEach(p=>{var a=document.createElement('a');a.className='menu-link';a.href=p.postUrl;a.innerText=p.postTitle;nav.appendChild(a)})})}).catch(e=>{console.error(e);nav.innerHTML='<div id=\"err-msg\">❌ 加载失败<br>原因: '+e.message+'<br>请尝试强制刷新页面</div>'});});</script>"
}
