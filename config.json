    "urlMode": "pinyin",
    "style": "",
    "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script src='https://blog.meekdai.com/Gmeek/plugins/lightbox.js'></script><script src='https://blog.meekdai.com/Gmeek/plugins/GmeekVercount.js'></script><script>document.addEventListener('DOMContentLoaded',function(){var style=document.createElement('style');style.innerHTML='/* 流动渐变背景 */ body{margin:0;padding:0;min-height:100vh;background-attachment:fixed;} body::before{content:\\\"\\\";position:fixed;top:0;left:0;width:100%;height:100%;z-index:-2;background:linear-gradient(125deg,#667eea 0%,#764ba2 25%,#f093fb 50%,#f5576c 75%,#4facfe 100%);background-size:400% 400%;animation:flowingGradient 20s ease infinite;} @keyframes flowingGradient{0%{background-position:0% 50%}25%{background-position:100% 50%}50%{background-position:100% 100%}75%{background-position:0% 100%}100%{background-position:0% 50%}} /* 左侧笔记目录 */ #note-toc{position:fixed;top:20px;left:20px;bottom:20px;width:280px;background:rgba(255,255,255,0.95);backdrop-filter:blur(10px);border-radius:16px;z-index:999;box-shadow:0 8px 32px rgba(0,0,0,0.1);display:flex;flex-direction:column;padding:20px;border:1px solid rgba(255,255,255,0.2);transition:transform 0.3s ease,opacity 0.3s ease;overflow:hidden;} #note-toc:hover{box-shadow:0 12px 40px rgba(0,0,0,0.15);} .toc-header{font-size:18px;font-weight:600;color:#333;margin-bottom:20px;padding-bottom:12px;border-bottom:2px solid rgba(103,126,234,0.2);display:flex;align-items:center;gap:8px;} .toc-header::before{content:\\\"📚\\\";font-size:20px;} .toc-content{flex:1;overflow-y:auto;overflow-x:hidden;padding-right:8px;} .toc-content::-webkit-scrollbar{width:4px;} .toc-content::-webkit-scrollbar-track{background:transparent;} .toc-content::-webkit-scrollbar-thumb{background:rgba(103,126,234,0.3);border-radius:2px;} .toc-level-1{margin:8px 0;font-weight:500;} .toc-level-2{margin:6px 0 6px 20px;font-weight:400;font-size:0.95em;} .toc-level-3{margin:4px 0 4px 40px;font-weight:400;font-size:0.9em;color:#666;} .toc-item{padding:8px 12px;margin:4px 0;border-radius:8px;cursor:pointer;transition:all 0.2s ease;color:#333;text-decoration:none;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;} .toc-item:hover{background:rgba(103,126,234,0.1);transform:translateX(4px);color:#667eea;} .toc-item.active{background:linear-gradient(135deg,rgba(103,126,234,0.15),rgba(118,75,162,0.15));color:#667eea;font-weight:500;border-left:3px solid #667eea;} /* 主内容区域适配 */ @media(min-width:1200px){ body{padding-left:320px!important;} .markdown-body, .FileList, #content{width:auto!important;margin:20px auto!important;max-width:1000px!important;background:rgba(255,255,255,0.95)!important;backdrop-filter:blur(10px);border-radius:16px;padding:40px!important;box-shadow:0 8px 32px rgba(0,0,0,0.1);border:1px solid rgba(255,255,255,0.2);} .Header, .footer{background:transparent!important;} } /* 移动端适配 */ @media(max-width:1199px){ #note-toc{transform:translateX(-100%);left:0;top:0;bottom:0;width:280px;border-radius:0 16px 16px 0;} #note-toc.open{transform:translateX(0);} #mobile-toc-toggle{display:flex!important;position:fixed;left:20px;top:20px;width:50px;height:50px;background:linear-gradient(135deg,#667eea,#764ba2);color:white;border-radius:50%;align-items:center;justify-content:center;font-size:20px;box-shadow:0 6px 20px rgba(103,126,234,0.4);z-index:10000;cursor:pointer;transition:all 0.3s ease;border:none;outline:none;} #mobile-toc-toggle:hover{transform:scale(1.1);box-shadow:0 8px 25px rgba(103,126,234,0.5);} .markdown-body, .FileList, #content{margin:10px!important;padding:20px!important;background:rgba(255,255,255,0.95)!important;border-radius:12px;backdrop-filter:blur(10px);} } /* 暗色主题适配 */ [data-color-mode=\\\"dark\\\"] #note-toc{background:rgba(30,30,30,0.95);border:1px solid rgba(255,255,255,0.1);} [data-color-mode=\\\"dark\\\"] .toc-header{color:#e1e4e8;border-bottom-color:rgba(255,255,255,0.1);} [data-color-mode=\\\"dark\\\"] .toc-item{color:#e1e4e8;} [data-color-mode=\\\"dark\\\"] .toc-item:hover{background:rgba(103,126,234,0.2);color:#a5b4fc;} [data-color-mode=\\\"dark\\\"] .toc-item.active{background:linear-gradient(135deg,rgba(103,126,234,0.25),rgba(118,75,162,0.25));color:#a5b4fc;} [data-color-mode=\\\"dark\\\"] .markdown-body, [data-color-mode=\\\"dark\\\"] .FileList, [data-color-mode=\\\"dark\\\"] #content{background:rgba(30,30,30,0.95)!important;border:1px solid rgba(255,255,255,0.1);}';document.head.appendChild(style);/* 创建左侧目录 */var noteToc=document.createElement('div');noteToc.id='note-toc';noteToc.innerHTML='<div class=\\\"toc-header\\\">笔记目录</div><div class=\\\"toc-content\\\" id=\\\"toc-content\\\"></div>';document.body.appendChild(noteToc);/* 创建移动端切换按钮 */var mobileToggle=document.createElement('button');mobileToggle.id='mobile-toc-toggle';mobileToggle.innerHTML='☰';mobileToggle.onclick=function(){noteToc.classList.toggle('open');};document.body.appendChild(mobileToggle);/* 生成目录 */function generateTOC(){var headers=document.querySelectorAll('h1, h2, h3, h4, h5, h6');var tocContent=document.getElementById('toc-content');tocContent.innerHTML='';if(headers.length===0){noteToc.style.display='none';return;}var currentLevel=0;var currentPath=[];headers.forEach(function(header,index){var level=parseInt(header.tagName.substring(1));var id=header.id||'header-'+index;if(!header.id){header.id=id;}var tocItem=document.createElement('a');tocItem.className='toc-item toc-level-'+level;tocItem.href='#'+id;tocItem.textContent=header.textContent.trim();tocItem.onclick=function(e){e.preventDefault();header.scrollIntoView({behavior:'smooth',block:'start'});document.querySelectorAll('.toc-item').forEach(function(item){item.classList.remove('active');});tocItem.classList.add('active');};tocContent.appendChild(tocItem);});}generateTOC();/* 监听滚动更新活动状态 */window.addEventListener('scroll',function(){var headers=document.querySelectorAll('h1, h2, h3, h4, h5, h6');var scrollPos=window.scrollY+100;var activeItem=null;headers.forEach(function(header){var rect=header.getBoundingClientRect();var top=rect.top+scrollPos;if(top<=scrollPos){activeItem=header;}});if(activeItem){var activeId=activeItem.id;document.querySelectorAll('.toc-item').forEach(function(item){item.classList.remove('active');if(item.getAttribute('href')=== '#'+activeId){item.classList.add('active');}}});});});</script>"
}
